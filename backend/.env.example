# Copy this file to backend/.env for local development.

DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
SITE_BASE_URL=http://localhost:8000
TRACKER_ANNOUNCE_BASE_URL=http://localhost:2710
XBT_SYNC_ENABLED=true

# Optional MySQL configuration.
# MYSQL_DATABASE=subtitle_group
# MYSQL_USER=subtitle
# MYSQL_PASSWORD=change-me
# MYSQL_HOST=localhost
# MYSQL_PORT=3306

# Optional Redis cache/session backend.
# REDIS_URL=redis://localhost:6379/0

# Optional XBT mirror database alias.
# XBT_SYNC_DATABASE_ALIAS=default

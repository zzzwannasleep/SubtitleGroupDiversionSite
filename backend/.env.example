APP_NAME=pt-platform
APP_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
JWT_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+psycopg2://ptuser:ptpass@postgres:5432/ptapp
REDIS_URL=redis://redis:6379/0
TORRENT_STORAGE_PATH=./data/torrents
UPLOAD_STORAGE_PATH=./data/uploads
PUBLIC_WEB_BASE_URL=http://localhost
TRACKER_IMPL=xbt
TRACKER_BASE_URL=http://localhost/announce
TRACKER_CREDENTIAL_MODE=path
TRACKER_CREDENTIAL_QUERY_KEY=passkey
TRACKER_SYNC_MODE=pull
TRACKER_USER_STATS_ENDPOINT=
TRACKER_TORRENT_STATS_ENDPOINT=
TRACKER_SYNC_TIMEOUT_SECONDS=10
ALLOW_PUBLIC_TORRENT_LIST=true
ALLOW_USER_REGISTRATION=true
# Prefer Alembic migrations in normal environments.
AUTO_CREATE_TABLES=false
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173

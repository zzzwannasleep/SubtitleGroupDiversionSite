# Required application settings.
DJANGO_SECRET_KEY=change-me-before-production
# Comma-separated hostnames only. Do not include http://, https://, paths, or ports.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
SITE_BASE_URL=https://example.com
MYSQL_DATABASE=subtitle_group
MYSQL_USER=subtitle
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

# Optional runtime settings.
LOG_LEVEL=INFO
HTTP_PORT=80

# Optional image settings. Change these when deploying locally built images.
BACKEND_IMAGE=ghcr.io/zzzwannasleep/subtitlegroupdiversionsite/backend:latest
IMAGE_PULL_POLICY=always

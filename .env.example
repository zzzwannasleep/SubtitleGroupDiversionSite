# Docker Compose variables. Copy this file to .env in the repository root.
#
# Default direct deployment:
WEB_HOST=0.0.0.0
WEB_PORT=80
#
# If an existing OpenResty/Nginx already owns public 80/443, use this instead:
# WEB_HOST=127.0.0.1
# WEB_PORT=8080
#
# Optional: use prebuilt GHCR images instead of local build.
# BACKEND_IMAGE=ghcr.io/zzzwannasleep/subtitlegroupdiversionsite-backend:main
# FRONTEND_IMAGE=ghcr.io/zzzwannasleep/subtitlegroupdiversionsite-frontend:main
# TRACKER_IMAGE=ghcr.io/zzzwannasleep/subtitlegroupdiversionsite-xbt-tracker:main
